# PostgreSQL async connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/chartapi

# LLM provider: "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic

# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# Set to DEBUG to enable SQLAlchemy query echo
LOG_LEVEL=INFO
